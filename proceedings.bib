@inproceedings{bhattacharya_low_2025,
	title = {{Low {Temperature} {Electroluminescence} of {AlGaN} based {UV} {Edge} {Emitting} {LEDs} grown by {MBE} on {Bulk} {AlN} {Substrates}}},
