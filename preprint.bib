
@misc{dill_low_2025,
	title = {Low {Resistance} {Non}-{Alloyed} {Ohmic} {Contacts} to {High} {Al} {Composition} n-type {AlGaN}},
	url = {http://arxiv.org/abs/2512.08871},
	doi = {10.48550/arXiv.2512.08871},
	abstract = {Ohmic contacts to high ({\textgreater}70{\textbackslash}\%) Al content n-type Al\$\_x\$Ga\$\_\{1-x\}\$N ultra-wide bandgap semiconductor layers in nitride electronic and photonic devices are typically fabricated by a lift-off process and high temperature (\${\textgreater}700{\textasciicircum}{\textbackslash}circ\$C) thermal alloying. These conditions often result in significant structural deformations of the fabricated structures and impose a harsh thermal budget on all other aspects of the device. Here, we report the fabrication of {\textbackslash}textit\{non-alloyed\} {\textbackslash}textit\{as-deposited\} ohmic contacts to 71{\textbackslash}\% n+AlGaN (\$E\_{\textbackslash}text\{g\}{\textbackslash}sim5.4\${\textasciitilde}eV) with a free carrier concentration of roughly \$7{\textbackslash}times 10{\textasciicircum}\{19\}\${\textasciitilde}cm\${\textasciicircum}\{-3\}\$ and a resistivity of 4 - 5.5 m\$Ω\$cm (among the lowest reported for Al\$\_\{0.71\}\$Ga\$\_\{0.29\}\$N) with linear \$I-V\$ characteristics and a contact resistivity of \$ρ\_{\textbackslash}text\{c\}=(4.4{\textbackslash}pm1.0){\textbackslash}times10{\textasciicircum}\{-4\}\${\textasciitilde}\$Ω\$cm\${\textasciicircum}2\$ (measured at zero voltage). Contacts with this quality are formed by two separate fabrication schemes: (i) metal-first patterning, and (ii) lift-off with an oxygen asher descum prior to metal deposition. Given the low threading dislocation density in the single-crystal AlN substrate used for epitaxy, the smooth morphology of the contacted epitaxial surface, and the non-alloyed nature of the contacts, this contact resistivity is attributed purely to thermionic field emission through the metal-semiconductor junction. Contact resistivity extraction at low current injection enables us to model these results using a thermionic field-emission model of contact resistivity, yielding a barrier height for Ti/Al\$\_\{0.71\}\$Ga\$\_\{0.29\}\$N of \$(0.81{\textbackslash}pm0.02)\$ eV.},
	urldate = {2026-02-27},
	publisher = {arXiv},
	author = {Dill, Joseph E. and Wei, Xianzhi and Yu, Changkai and Arvind, Akhansha and Agrawal, Shivali and \textbf{D. Bhattacharya} and Shinohara, Keisuke and Jena, Debdeep and Xing, Huili Grace},
	month = dec,
	year = {2025},
	note = {arXiv:2512.08871 [cond-mat]},
	keywords = {Condensed Matter - Materials Science},
	file = {Preprint PDF:C\:\\Users\\debbh\\Zotero\\storage\\WWKEVYLW\\Dill et al. - 2025 - Low Resistance Non-Alloyed Ohmic Contacts to High Al Composition n-type AlGaN.pdf:application/pdf;Snapshot:C\:\\Users\\debbh\\Zotero\\storage\\25QSD92H\\2512.html:text/html},
}


